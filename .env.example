# Supabase — obter em https://supabase.com/dashboard/project/<project-id>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://<project-id>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
# Personal Access Token — usado por scripts/apply-migration-*.mjs (Management API). Opcional no dia a dia.
SUPABASE_PAT=<supabase-personal-access-token>

# Google OAuth — obter em https://console.cloud.google.com (APIs & Services > Credentials)
# Redirect URIs: <APP_URL>/auth/callback (staff) e <APP_URL>/api/auth/google/callback (aluno)
GOOGLE_CLIENT_ID=<client-id>.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=<client-secret>

# Assinatura do cookie de sessão do aluno (HMAC-SHA256) — gere com: openssl rand -base64 32
# NÃO reutilizar a service_role key aqui (ver histórico de segurança no ONBOARDING.md)
SESSION_SIGNING_SECRET=<random-32-bytes-base64>

# Groq — avaliação de questões abertas por IA + OCR Vision. Obter em https://console.groq.com/keys
GROQ_API_KEY=gsk_<key>

# Resend — obter em https://resend.com/api-keys
RESEND_API_KEY=re_<key>
RESEND_FROM_EMAIL=olimpiadas@raizeducacao.com.br

# Sentry — obter em https://sentry.io
NEXT_PUBLIC_SENTRY_DSN=https://<key>@<org>.ingest.sentry.io/<project-id>
SENTRY_AUTH_TOKEN=<auth-token>
SENTRY_ORG=raiz-educacao
SENTRY_PROJECT=olimpiadas-raiz

# Integração raiz-data-engine (sincronização de dados da rede) — opcional em dev local
RAIZ_DATA_ENGINE_URL=<url-do-serviço>
RAIZ_DATA_ENGINE_TOKEN=<token>

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
